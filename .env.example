# ─── BASE DE DATOS ────────────────────────────────────────────────────────────
# Turso (producción): https://turso.tech → crear DB → copiar URL y token
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# SQLite local (desarrollo): solo si no usas Turso localmente
# DATABASE_URL=file:/ruta/absoluta/al/repo/prisma/dev.db

# ─── ARCHIVOS ─────────────────────────────────────────────────────────────────
# UploadThing (producción): https://uploadthing.com → crear app → copiar token
UPLOADTHING_TOKEN=your-uploadthing-token-here

# ─── SEED ─────────────────────────────────────────────────────────────────────
# Clave secreta para el endpoint /api/seed (pon cualquier string aleatorio)
SEED_SECRET=cambia-esto-por-algo-secreto
